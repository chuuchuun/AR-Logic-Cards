# Vuforia (no special ignores needed, but keep the license key out)
/*.unitypackage
/VuforiaConfiguration.asset  # but you may want to keep it if shared

# Unity Package Manager
/[Pp]ackages/

# Autogenerated by Unity
/Assets/AssetStoreTools*

# Crash reports
/[Cc]rashes/

# Memory dumps
*.mem
*.dump

# Backup files
*.bak
*.tmp

# Unity3D generated meta files (optional, but usually keep them)
# *.meta should be tracked, so don't ignore them