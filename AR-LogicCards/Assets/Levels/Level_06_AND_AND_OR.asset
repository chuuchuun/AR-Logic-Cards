  levelName: AND-AND-OR
  description: Four inputs, all set to 1. Build the circuit that gives this result
    using two ANDs and one OR.
  successMessage: "Amazing! You mastered multi\u2011gate circuits."
  requiredCardNames:
  - Input_zero_card
  - Input_one_card
  - Input_one_card_2
